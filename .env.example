# Copy to .env and fill in. NEVER commit .env.
# This file is safe to commit — it has no secrets.

# Moca Testnet (chain 222888)
MOCA_TESTNET_RPC=https://rpc.testnet.mocachain.dev

# Moca Mainnet (chain 2288) — requires API key, leave blank until needed
MOCA_MAINNET_RPC=

# Deployer private key (hex, no 0x prefix or with 0x prefix both work with cast)
# Generate a fresh key for deploys: cast wallet new
PRIVATE_KEY=

# Optional: block explorer API key for `forge verify-contract`
MOCA_SCAN_KEY=
